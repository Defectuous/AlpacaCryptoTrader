# Alpaca API credentials
# Get these from https://alpaca.markets (paper trading is free)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Set to "true" for paper trading (safe, no real money), "false" for live
ALPACA_PAPER=true

# Optional: Discord webhook URL for trade alerts
DISCORD_WEBHOOK_URL=
